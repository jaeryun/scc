# =================================================================
# Database Configuration
# =================================================================

DATABASE_URL="postgresql://user:password@localhost:5432/dbname"


# =================================================================
# Build Configuration
# =================================================================
# Set to 'true' when deploying with Docker or self-hosting on a VPS.
# This enables Next.js standalone output mode for smaller deployments.

BUILD_STANDALONE=


# =================================================================
# NetBox Configuration
# =================================================================
# NetBox instance URL and API token for switch port mapping data source.
# Create a token at: Admin → Users → API Tokens in your NetBox instance.

NETBOX_URL=http://localhost:8000
NETBOX_TOKEN=

# NetBox SoT
NETBOX_BASE_URL=https://netbox.internal.example.com
NETBOX_API_TOKEN=your-40-char-api-token-here
NETBOX_CACHE_TTL_SECONDS=300


# =================================================================
# Important Notes:
# =================================================================
# 1. Rename this file to '.env' for local development
# 2. Never commit the actual '.env' file to version control
# 3. Keep your secret keys private and never share them
